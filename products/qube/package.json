{
  "name": "@tjalve/qube",
  "version": "0.1.1",
  "description": "QUBE composer CLI for coordinating the standalone planning, execution, quality, and continuation tools.",
  "keywords": [
    "cli",
    "agent",
    "automation",
    "planning",
    "quality"
  ],
  "author": "tjalve",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZarK/ai-qube.git",
    "directory": "products/qube"
  },
  "bugs": {
    "url": "https://github.com/ZarK/ai-qube/issues"
  },
  "homepage": "https://github.com/ZarK/ai-qube/tree/main/products/qube#readme",
  "packageManager": "pnpm@11.0.4",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "bin": {
    "qube": "bin/run"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@tjalve/aib": "0.1.1",
    "@tjalve/aie": "0.1.4",
    "@tjalve/aiq": "0.2.2",
    "@tjalve/aiu": "0.0.4",
    "@tjalve/qube-cli": "0.1.2"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test --test-concurrency=1 \"test/*.test.mjs\"",
    "prepack": "pnpm run build",
    "pack:check": "pnpm run build && pnpm pack --dry-run --json",
    "verify": "pnpm run typecheck && pnpm test && pnpm run pack:check"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "typescript": "6.0.3"
  }
}

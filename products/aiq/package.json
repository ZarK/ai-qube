{
  "name": "ai-code-quality",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "packageManager": "pnpm@11.0.4",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "packages/benchmark",
    "packages/cli",
    "packages/config-schema",
    "packages/model",
    "packages/engine",
    "packages/reporters",
    "packages/lsp",
    "packages/hook",
    "packages/github-action",
    "packages/opencode-plugin"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/build-aiq-package.mjs && node scripts/build-github-action-bundle.mjs",
    "build:github-action-bundle": "node scripts/build-github-action-bundle.mjs",
    "bench": "node packages/cli/dist/bin/aiq.js bench --format text",
    "bench:ci": "node packages/cli/dist/bin/aiq.js bench --tag ci --format json",
    "aiq:e2e": "vitest run packages/cli/test/cli.test.ts packages/engine/test/engine.test.ts packages/github-action/test/action.test.ts packages/hook/test/hook.test.ts packages/opencode-plugin/test/opencode-plugin.test.ts",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:publish-readiness": "node scripts/run-smoke-tests.mjs",
    "test:smoke": "node scripts/run-smoke-tests.mjs",
    "lint": "biome check README.md package.json tsconfig.base.json tsconfig.json biome.json vitest.config.ts packages/benchmark packages/cli packages/config-schema packages/model packages/engine packages/reporters packages/lsp packages/hook packages/github-action packages/opencode-plugin",
    "format": "biome format --write README.md package.json tsconfig.base.json tsconfig.json biome.json vitest.config.ts packages/benchmark packages/cli packages/config-schema packages/model packages/engine packages/reporters packages/lsp packages/hook packages/github-action packages/opencode-plugin"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tjalve/aie": "0.1.4",
    "@tjalve/aiu": "0.0.4",
    "@types/node": "24.12.0",
    "@vitest/coverage-v8": "3.2.6",
    "esbuild": "0.28.1",
    "jest": "29.7.0",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZarK/ai-quality.git"
  },
  "bugs": {
    "url": "https://github.com/ZarK/ai-quality/issues"
  },
  "homepage": "https://github.com/ZarK/ai-quality#readme"
}

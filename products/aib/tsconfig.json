{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "verbatimModuleSyntax": true
  },
  "include": [
    ".agent/plugins/opencode/**/*.ts",
    "src/**/*.ts",
    "types/**/*.d.ts"
  ]
}

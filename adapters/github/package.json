{
  "name": "@tjalve/qube-adapter-github",
  "version": "0.1.0",
  "description": "Private GitHub adapter boundary for QUBE issue and review provider integrations.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.0.4",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test \"test/*.test.mjs\"",
    "verify": "pnpm run typecheck && pnpm test"
  },
  "dependencies": {
    "@tjalve/qube-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "typescript": "6.0.3"
  }
}

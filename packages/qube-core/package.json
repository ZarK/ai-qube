{
  "name": "@tjalve/qube-core",
  "version": "0.1.1",
  "description": "Shared QUBE product, provider, review, and adapter contracts.",
  "type": "module",
  "license": "MIT",
  "author": "tjalve",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZarK/ai-qube.git",
    "directory": "packages/qube-core"
  },
  "bugs": {
    "url": "https://github.com/ZarK/ai-qube/issues"
  },
  "homepage": "https://github.com/ZarK/ai-qube/tree/main/packages/qube-core#readme",
  "packageManager": "pnpm@11.0.4",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test \"test/*.test.mjs\"",
    "verify": "pnpm run typecheck && pnpm test"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "typescript": "6.0.3"
  }
}

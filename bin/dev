#!/usr/bin/env node

const fs = require('fs')
const path = require('path')

function getPackageVersion() {
  try {
    const pkgPath = path.join(__dirname, '..', 'package.json')
    const pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf8'))
    return pkg.version || '0.0.0'
  } catch {
    return '0.0.0'
  }
}

const args = process.argv.slice(2)

if (args.includes('--version') || args.includes('-v')) {
  // eslint-disable-next-line no-console
  console.log(getPackageVersion())
  process.exit(0)
}

if (args.includes('--help') || args.includes('-h') || args.length === 0) {
  // eslint-disable-next-line no-console
  console.log(`aie (dev) - AI Executor

Usage:
  ./bin/dev --version
  ./bin/dev --help

Development entrypoint. Full commands added in M1.2.
`)
  process.exit(0)
}

const { execute } = require('@oclif/core')

execute({ dir: __dirname, development: true })
  .catch((error) => {
    if (error && (error.code === 'MODULE_NOT_FOUND' || /no commands/i.test(String(error)))) {
      // eslint-disable-next-line no-console
      console.error('aie: command not implemented in M1.1 scaffold. Use --version or --help.')
      process.exit(2)
    }
    // eslint-disable-next-line no-console
    console.error(error)
    process.exitCode = 1
  })

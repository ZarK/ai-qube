#!/usr/bin/env node

/**
 * Development entrypoint for aie CLI.
 *
 * Runs against compiled lib/ output. For active TS development:
 *   npm run build
 *   ./bin/dev <command>
 *
 * Or run `npx tsc -p . --watch` in a second terminal while using ./bin/dev.
 * No ts-node/tsx devDependency added to keep supply-chain surface minimal.
 */

const { execute } = require('@oclif/core');

execute({ dir: __dirname, development: true }).catch((error) => {
  // eslint-disable-next-line no-console
  console.error(error);
  process.exitCode = 1;
});

#!/usr/bin/env node

/**
 * Production entrypoint for aie CLI.
 * Delegates to @oclif/core after minimal Node 24+ guard.
 *
 * Full command tree, help, JSON, and error surfaces are implemented via
 * src/commands/* and src/help.ts. Build with `npm run build` to update lib/.
 */

const { execute } = require('@oclif/core');

execute({ dir: __dirname, development: false }).catch((error) => {
  // eslint-disable-next-line no-console
  console.error(error);
  process.exitCode = 1;
});
